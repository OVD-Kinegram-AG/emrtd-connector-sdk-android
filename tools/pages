#!/usr/bin/env bash

# The product documentation moved to https://docs.kinegram.digital and the
# API references (Dokka/JavaDoc) to docs.kinegram.digital/reference/. 
# This script writes redirect stubs for all old documentation pages into _site

# Exit on error.
set -e

DOCS=https://docs.kinegram.digital/mobile-chip-sdk/online/emrtd-connector/android
REFERENCE=https://docs.kinegram.digital/reference/emrtd-connector-android/latest

# Clear/Create output directory.
rm -rf _site
mkdir _site

# stub <name> <target-url>: write a redirect page to _site/<name>.html.
stub() {
	cat >"_site/$1.html" <<EOF
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Moved to docs.kinegram.digital</title>
<meta name="robots" content="noindex">
<meta http-equiv="refresh" content="0; url=$2">
<link rel="canonical" href="$2">
<link rel="icon" href="favicon.svg">
</head>
<body>
<p>This page has moved to <a href="$2">$2</a>.</p>
</body>
</html>
EOF
}

stub index "$DOCS/"
stub CHANGELOG "$DOCS/changelog"

mkdir -p _site/dokka _site/javadoc
stub dokka/index "$REFERENCE/dokka/"
stub javadoc/index "$REFERENCE/javadoc/"

# Copy resources.
cp kinegram-emrtd-connector/logo-icon.svg _site/favicon.svg
